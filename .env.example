# AI Signal Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains API keys.

# ── Alpaca ──────────────────────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here
# Set to true for paper trading, false for live
ALPACA_PAPER=true

# ── Anthropic (Claude AI) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Telegram ─────────────────────────────────────────────────────────────────
# Create a bot at https://t.me/BotFather to get the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your Telegram chat ID (send /start to @userinfobot to find it)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Bot mode ─────────────────────────────────────────────────────────────────
# shadow = no real orders, just log + telegram
# paper  = real orders on Alpaca paper account
# live   = real orders on Alpaca live account (use with caution!)
MODE=paper
